{
  "name": "byteboundless",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@byteboundless/web",
    "dev:worker": "turbo dev --filter=@byteboundless/worker",
    "build:web": "turbo build --filter=@byteboundless/web"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.2"
}
